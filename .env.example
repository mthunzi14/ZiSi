# =============================================================================
# ZiSi Bot — Environment Template
# =============================================================================
# Copy this file to `.env` and fill in real values. NEVER commit `.env`
# (it is already in .gitignore). If any real key has ever been pasted into a
# chat, screenshot, or shared doc, ROTATE it before going live.
#
# Only the Polymarket API URLs are strictly required (see config.py
# _REQUIRED_KEYS). Everything else has a safe default or is optional.
# =============================================================================

# ── Polymarket (REQUIRED) ────────────────────────────────────────────────────
POLYMARKET_GAMMA_API_URL=https://gamma-api.polymarket.com
POLYMARKET_DATA_API_URL=https://data-api.polymarket.com
POLYMARKET_CLOB_API_URL=https://clob.polymarket.com
# Only needed for LIVE trading (signing CLOB orders). Leave blank for paper.
POLYMARKET_PRIVATE_KEY=
POLYMARKET_PROXY_ADDRESS=

# ── Market data provider (optional) ──────────────────────────────────────────
PMXT_API_KEY=
PMXT_ALWAYS_RESTART=false

# ── Bot meta ─────────────────────────────────────────────────────────────────
BOT_NAME=ZiSi
BOT_VERSION=2.0
# paper_trading | live_trading
BOT_MODE=paper_trading

# ── Kalshi (UNUSED — kept for backward compat; leave blank) ──────────────────
KALSHI_EMAIL=
KALSHI_PASSWORD=
KALSHI_API_KEY=
KALSHI_PRIVATE_KEY=

# ── Google Drive / Gmail reporting (optional) ────────────────────────────────
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_CREDENTIALS_FILE=credentials.json
GMAIL_SENDER_EMAIL=
GMAIL_APP_PASSWORD=
GMAIL_ENABLED=false
EMAIL_INTERVAL_HOURS=24

# ── Telegram alerts (optional) ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Risk / sizing ────────────────────────────────────────────────────────────
RISK_PER_TRADE_PERCENT=2
MAX_SIMULTANEOUS_TRADES=6
MIN_EVENT_LIQUIDITY_USD=500
STOP_LOSS_PCT=
TAKE_PROFIT_PCT=

# ── Position management ──────────────────────────────────────────────────────
POSITION_TARGET_MULTIPLIER=1.5
POSITION_STOP_LOSS_MULTIPLIER=0.50
POSITION_HOLD_TIME_HOURS=24

# ── Logging / reporting ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_TO_DRIVE=true
LOG_TO_CONSOLE=true
DAILY_REPORT_TIME=09:00
DAILY_REPORT_EMAIL=true

# ── API behaviour ────────────────────────────────────────────────────────────
API_TIMEOUT_SECONDS=10
API_RETRY_COUNT=3
API_RETRY_BACKOFF_SECONDS=5
